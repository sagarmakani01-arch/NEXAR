# Application
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# Database
DB_PATH=./data/ai-builder.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_builder

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=30d

# Nemotron 3 Ultra API
# Get your key from: https://build.nvidia.com/nvidia/nemotron-3-ultra
NEMOTRON_API_KEY=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

# Deployment
PROJECTS_DIR=./data/projects
BUILD_DIR=./data/builds
DEPLOY_DIR=./data/deployments
DEPLOY_DOMAIN=localhost
DEPLOY_PORT=8080
DEPLOY_SSL=false

# Rate Limiting (generous for unlimited tasks)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./data/uploads
